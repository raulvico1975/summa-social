# Copia aquest fitxer a .env.local i omple només les variables que necessitis.

# Gemini runtime (per defecte: gemini-3.1-flash-lite-preview)
GOOGLE_API_KEY=
GOOGLE_GENAI_API_KEY=
# Alternativa compatible si prefereixes aquest nom
GEMINI_API_KEY=
GOOGLE_GENAI_MODEL=
# Alternativa compatible si prefereixes aquest nom
GEMINI_MODEL=

# Blog generator LLM
OPENAI_API_KEY=
BLOG_WRITER_PROVIDER=openai
BLOG_WRITER_MODEL=gpt-5

# Email transaccional
RESEND_API_KEY=

# Publicació del blog
BLOG_PUBLISH_SECRET=
BLOG_PUBLISH_BASE_URL=http://127.0.0.1:9002

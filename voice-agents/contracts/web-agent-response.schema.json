{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WebAgentResponse",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "agent_message",
    "fit_assessment",
    "signals_collected",
    "next_question",
    "qualification_summary",
    "recommended_next_step",
    "ui_action"
  ],
  "properties": {
    "agent_message": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1200
    },
    "fit_assessment": {
      "type": "string",
      "enum": [
        "good_fit",
        "uncertain_fit",
        "low_fit"
      ]
    },
    "signals_collected": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entity_type",
        "team_size",
        "primary_pain",
        "exclusion_reason"
      ],
      "properties": {
        "entity_type": {
          "type": ["string", "null"],
          "maxLength": 200
        },
        "team_size": {
          "type": ["string", "null"],
          "maxLength": 200
        },
        "primary_pain": {
          "type": ["string", "null"],
          "maxLength": 200
        },
        "exclusion_reason": {
          "type": ["string", "null"],
          "maxLength": 200
        }
      }
    },
    "next_question": {
      "type": ["string", "null"],
      "maxLength": 400
    },
    "qualification_summary": {
      "type": ["string", "null"],
      "maxLength": 600
    },
    "recommended_next_step": {
      "type": "string",
      "enum": [
        "ask_more",
        "show_value",
        "offer_demo",
        "capture_contact",
        "disqualify"
      ]
    },
    "ui_action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "component", "props"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["none", "render_component"]
        },
        "component": {
          "type": "string",
          "enum": [
            "None",
            "ChoiceSelector",
            "FeatureCard",
            "LeadCaptureForm",
            "QualificationSummaryCard"
          ]
        },
        "props": {
          "type": "object"
        }
      }
    }
  }
}
